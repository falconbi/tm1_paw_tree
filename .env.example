# ── CubeMap (required) ──────────────────────────────────────────
TM1_ADDRESS=192.168.x.x
TM1_PORT=4444
TM1_DATABASE=YourDatabaseName
TM1_CLIENT_ID=your_client_id_here
TM1_CLIENT_SECRET=your_client_secret_here
TM1_USER=admin

# ── CubeMap — AI spec generation (optional) ─────────────────────
ANTHROPIC_API_KEY=

# ── PAW Tree (optional — separate tool, requires PAW + Authentik) ─
PAW_HOST=http://192.168.x.x
PAW_ACCOUNT_ID=your_account_id_here
PAW_TENANT_ID=your_tenant_id_here

AUTHENTIK_HOST=http://192.168.x.x:9000
AUTHENTIK_USERNAME=admin
AUTHENTIK_PASSWORD=your_password_here
